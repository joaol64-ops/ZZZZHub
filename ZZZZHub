			if humanoid then
				local currentState = getSpeedToggle()
				local currentSpeedValue = getSpeedValue()
				
				if currentState then
					-- Speed ativado
					if humanoid.WalkSpeed ~= currentSpeedValue then
						humanoid.WalkSpeed = currentSpeedValue
						lastSpeedValue = currentSpeedValue
					end
				else
					-- Speed desativado
					if humanoid.WalkSpeed ~= 16 then
						humanoid.WalkSpeed = 16
						lastSpeedValue = 16
					end
				end
			end
		end
	end
end)

