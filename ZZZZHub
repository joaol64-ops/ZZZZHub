-- SUPER JUMP CORRIGIDO (Pulo múltiplo)
local superJumpActive = false
local lastJumpTime = 0

-- Função para permitir pulo múltiplo
local function setupSuperJump(character)
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		-- Aumenta o JumpPower
		humanoid.JumpPower = 120
		
		-- Remove a limitação de pulo no ar
		local function onJumpRequest()
			if superJumpActive then
				-- Permite pular novamente mesmo no ar
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end
		
		-- Conecta no pulo
		local jumpConnection
		jumpConnection = humanoid:GetPropertyChangedSignal("Jump"):Connect(function()
			if superJumpActive and humanoid.Jump and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
				task.wait(0.05)
				if superJumpActive then
					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end)
		
		return jumpConnection
	end
end

-- Monitora o Super Jump
local superJumpConnection = nil

RunService.RenderStepped:Connect(function()
	local newState = getJump()
	
	if newState ~= superJumpActive then
		superJumpActive = newState
		
		if superJumpActive and player.Character then
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid.JumpPower = 120
			end
		elseif not superJumpActive and player.Character then
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid.JumpPower = 50
			end
		end
	end
	
	-- Mantém o JumpPower enquanto ativo
	if superJumpActive and player.Character then
		local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
		if humanoid and humanoid.JumpPower ~= 120 then
			humanoid.JumpPower = 120
		end
	end
end)

